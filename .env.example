# ─────────────────────────────────────────────────────────────────────────────
# KYISA CMS — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── DJANGO CORE ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite (default, good for development):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://kyisa_user:your_password@localhost:5432/kyisa_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your frontend URL(s) here
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── EMAIL ─────────────────────────────────────────────────────────────────────
# Development: use console backend (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production (Gmail example):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ── STORAGE ───────────────────────────────────────────────────────────────────
# Local storage (default). For production, use S3:
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=kyisa-cms-media
# AWS_S3_REGION_NAME=af-south-1
