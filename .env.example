# ─────────────────────────────────────────────────────────────────────────────
# MKJ SUPA CUP CMS - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── DJANGO CORE ───────────────────────────────────────────────────────────────
# REQUIRED - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Production example:
# DEBUG=False
# ALLOWED_HOSTS=mkjsupacup.go.ke,www.mkjsupacup.go.ke

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite (default, good for development):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production):
# DATABASE_URL=postgres://mkj_user:your_password@localhost:5432/mkj_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your frontend URL(s) here
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── EMAIL ─────────────────────────────────────────────────────────────────────
# Development: use console backend (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production (Gmail example):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Brevo (preferred for production — bypasses SMTP port restrictions):
# EMAIL_BACKEND=accounts.brevo_backend.BrevoEmailBackend
# BREVO_API_KEY=xkeysib-your-brevo-api-key-here

# ── WHATSAPP (Meta Cloud API) ─────────────────────────────────────────────────
# 1. Go to https://developers.facebook.com → Create App → Add WhatsApp product
# 2. Get your Phone Number ID and generate a permanent system user token
# 3. Create and get approval for message templates in Meta Business Manager
#    Template language: English (en_US)
META_WA_TOKEN=your-meta-system-user-token-here
META_WA_PHONE_ID=your-whatsapp-phone-number-id-here
# Template names (must match exactly what you registered in Meta Business Manager):
META_WA_TEMPLATE_CREDENTIALS=mkj_credentials
META_WA_TEMPLATE_PASSWORD_RESET=mkj_password_reset
META_WA_TEMPLATE_DEADLINE=mkj_deadline
META_WA_TEMPLATE_TRANSFER=mkj_transfer_update
META_WA_TEMPLATE_LONGLIST_STATUS=mkj_longlist_status
META_WA_TEMPLATE_MATCH_RESULT=mkj_match_result

# ── STORAGE ───────────────────────────────────────────────────────────────────
# Local storage (default). For production, use S3:
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=mkj-supacup-media
# AWS_S3_REGION_NAME=af-south-1
