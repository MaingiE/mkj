# Production environment — Railway + mkjsupacup.com
# Set these as Railway environment variables (not committed to git)

SECRET_KEY=replace-with-strong-production-secret
DEBUG=False

# ── DOMAIN ─────────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=mkjsupacup.com,www.mkjsupacup.com
CSRF_TRUSTED_ORIGINS=https://mkjsupacup.com,https://www.mkjsupacup.com
CORS_ALLOWED_ORIGINS=https://mkjsupacup.com,https://www.mkjsupacup.com
SITE_URL=https://mkjsupacup.com

# ── DATABASE (Railway PostgreSQL — Railway injects DATABASE_URL automatically) ─
# Leave blank if using Railway's managed Postgres plugin (it sets this auto)
DATABASE_URL=

# ── REDIS (Railway Redis plugin injects REDIS_URL automatically) ───────────────
REDIS_URL=

# ── EMAIL ──────────────────────────────────────────────────────────────────────
# Option A: Google Workspace SMTP (recommended for @mkjsupacup.com accounts)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=info@mkjsupacup.com
EMAIL_HOST_PASSWORD=your-google-workspace-app-password
DEFAULT_FROM_EMAIL=MKJ SUPA CUP <info@mkjsupacup.com>

# Option B: SendGrid (alternative transactional email)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# ── MONITORING ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ADMINS=Admin:info@mkjsupacup.com
SERVER_EMAIL=info@mkjsupacup.com

# ── S3 MEDIA STORAGE ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=mkj-supacup-media
AWS_S3_REGION_NAME=af-south-1
AWS_S3_CUSTOM_DOMAIN=
