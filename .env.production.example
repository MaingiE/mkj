# Production environment - Railway + mkjsupacup.com
# Set these as Railway environment variables (not committed to git)

SECRET_KEY=replace-with-strong-production-secret
DEBUG=False

# ── DOMAIN ─────────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=mkjsupacup.com,www.mkjsupacup.com,.railway.app
CSRF_TRUSTED_ORIGINS=https://mkjsupacup.com,https://www.mkjsupacup.com
CORS_ALLOWED_ORIGINS=https://mkjsupacup.com,https://www.mkjsupacup.com
SITE_URL=https://mkjsupacup.com

# ── DATABASE (Railway PostgreSQL plugin injects this automatically) ─────────────
DATABASE_URL=

# ── REDIS (Railway Redis plugin injects this automatically) ───────────────────
REDIS_URL=

# ── EMAIL (Brevo HTTP API — works on Railway, no SMTP port issues) ─────────────
# 1. Get API key from: Brevo → Settings → API Keys
# 2. Add mkjsupacup.com in Brevo → Senders → Domains and complete SPF/DKIM setup
# 3. Add info@mkjsupacup.com and ligimashinani@mkjsupacup.com as verified senders
EMAIL_BACKEND=accounts.brevo_backend.BrevoEmailBackend
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
DEFAULT_FROM_EMAIL=MKJ SUPA CUP <info@mkjsupacup.com>
LIGI_FROM_EMAIL=Ligi Mashinani <ligimashinani@mkjsupacup.com>

# ── WHATSAPP (Brevo WhatsApp API) ─────────────────────────────────────────────
# 1. Brevo → WhatsApp → Connect your WhatsApp Business number
# 2. Create templates in Brevo (WhatsApp → Templates) — see notifications.py for variable details
# 3. Set template IDs (numbers shown after creation in Brevo dashboard)
BREVO_WHATSAPP_SENDER=+254XXXXXXXXX
BREVO_WHATSAPP_TEMPLATE_CREDENTIALS=
BREVO_WHATSAPP_TEMPLATE_PASSWORD_RESET=
BREVO_WHATSAPP_TEMPLATE_DEADLINE=
BREVO_WHATSAPP_TEMPLATE_TRANSFER=
BREVO_WHATSAPP_TEMPLATE_LONGLIST_STATUS=
BREVO_WHATSAPP_TEMPLATE_SQUAD_RESULT=

# ── MONITORING ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ADMINS=Admin:info@mkjsupacup.com
SERVER_EMAIL=info@mkjsupacup.com

# ── CLOUDINARY MEDIA STORAGE ───────────────────────────────────────────────────
# Preferred over S3 for Railway (no egress issues)
# Get from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── S3 MEDIA STORAGE (alternative to Cloudinary) ──────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=mkj-supacup-media
# AWS_S3_REGION_NAME=af-south-1
# AWS_S3_CUSTOM_DOMAIN=
