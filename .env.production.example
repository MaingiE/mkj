# Production environment (AWS server)
# Copy to .env on server only (never commit secrets)

SECRET_KEY=replace-with-strong-production-secret
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# PostgreSQL in production
DATABASE_URL=postgres://mkj_user:change_me_password@localhost:5432/mkj_supacup

# Redis in production
REDIS_URL=redis://127.0.0.1:6379/0

# SMTP for real email sending
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Monitoring and alerting
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ADMINS=Admin:admin@yourdomain.com
SERVER_EMAIL=noreply@yourdomain.com

# S3 media storage
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=mkj-supacup-media
AWS_S3_REGION_NAME=af-south-1
AWS_S3_CUSTOM_DOMAIN=
