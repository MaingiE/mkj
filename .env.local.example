# Local development environment (Machine A / Machine B)
# Copy to .env for local work
# Keep DEBUG=True locally for runserver and easier debugging

SECRET_KEY=replace-with-local-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Local DB (recommended for development)
DATABASE_URL=sqlite:///mkj_supacup.db

# Local redis (optional in dev)
REDIS_URL=redis://127.0.0.1:6379/0

# Dev email to console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional monitoring (usually empty in local)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
ADMINS=
SERVER_EMAIL=

# Keep empty locally unless you are testing S3 uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=af-south-1
AWS_S3_CUSTOM_DOMAIN=
